package com.example.demo;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import java.time.LocalDate;
import java.time.temporal.ChronoUnit;
import java.util.*;
import java.util.stream.Collectors;


@Service
public class BookIssueService {
    
    @Autowired
    private BookIssueRepository bookIssueRepository;
    
    @Autowired
    private BookRepository bookRepository;
    
    public boolean hasActiveIssueForBook(Long bookId) {
        return !bookIssueRepository.findByBookIdAndStatus(bookId, "ISSUED").isEmpty();
    }
    
    // Issue a book to a member (Librarian full issue)
    public BookIssue issueBook(Long bookId, String memberName, String memberEmail) {
        Book book = bookRepository.findById(bookId).orElse(null);
        if (book == null) return null;
        
        // Check if book already has active issue or reserve
        if (hasActiveIssueOrReserve(bookId)) {
            return null;
        }
        
        BookIssue issue = new BookIssue();
        issue.setBookId(bookId);
        issue.setBookTitle(book.getTitle());
        issue.setMemberName(memberName);
        issue.setMemberEmail(memberEmail);
        issue.setIssueDate(LocalDate.now());
        issue.setDueDate(LocalDate.now().plusDays(14));
        issue.setStatus("ISSUED");
        issue.setFineAmount(0.0);
        
        // Update book availability
        book.setAvailabilityStatus("Issued");
        bookRepository.save(book);
        
        return bookIssueRepository.save(issue);
    }
    
    // Reserve book for member (doesn't change availability)
    public BookIssue reserveBook(Long bookId, String memberName, String memberEmail) {
        Book book = bookRepository.findById(bookId).orElse(null);
        if (book == null) return null;
        
        // Check if already reserved/issued by anyone
        if (hasActiveIssueOrReserve(bookId)) {
            return null;
        }
        
        BookIssue reserve = new BookIssue();
        reserve.setBookId(bookId);
        reserve.setBookTitle(book.getTitle());
        reserve.setMemberName(memberName);
        reserve.setMemberEmail(memberEmail);
        reserve.setIssueDate(LocalDate.now());
        reserve.setDueDate(LocalDate.now().plusDays(2));  // 2 days to pickup
        reserve.setStatus("RESERVED");
        reserve.setFineAmount(0.0);
        
        // Book stays Available for librarian to issue
        bookIssueRepository.save(reserve);
        return reserve;
    }
    
    // Check if book has active issue or reserve by anyone
    private boolean hasActiveIssueOrReserve(Long bookId) {
        List<BookIssue> active = bookIssueRepository.findByBookIdAndStatus(bookId, "ISSUED");
        active.addAll(bookIssueRepository.findByBookIdAndStatus(bookId, "RESERVED"));
        return !active.isEmpty();
    }
    
    // Return a book and calculate fine
    public BookIssue returnBook(Long issueId) {
        BookIssue issue = bookIssueRepository.findById(issueId).orElse(null);
        if (issue == null) return null;
        
        LocalDate returnDate = LocalDate.now();
        issue.setReturnDate(returnDate);
        
        long overdueDays = ChronoUnit.DAYS.between(issue.getDueDate(), returnDate);
        if (overdueDays > 0) {
            issue.setStatus("OVERDUE");
            issue.setFineAmount(overdueDays * 10.0);
        } else {
            issue.setStatus("RETURNED");
            issue.setFineAmount(0.0);
        }
        
        // Update book availability
        Book book = bookRepository.findById(issue.getBookId()).orElse(null);
        if (book != null) {
            book.setAvailabilityStatus("Available");
            bookRepository.save(book);
        }
        
        return bookIssueRepository.save(issue);
    }
    
    // Get all book issues
    public List<BookIssue> getAllIssues() {
        return bookIssueRepository.findAll();
    }
    
    // Get active issues
    public List<BookIssue> getActiveIssues() {
        List<BookIssue> all = bookIssueRepository.findAll();
        return all.stream()
                .filter(i -> "ISSUED".equals(i.getStatus()))
                .collect(Collectors.toList());
    }
    
    // Get overdue issues
    public List<BookIssue> getOverdueIssues() {
        List<BookIssue> all = bookIssueRepository.findAll();
        return all.stream()
                .filter(BookIssue::isOverdue)
                .collect(Collectors.toList());
    }
    
    // Counts
    public long getIssuedCount() {
        return getActiveIssues().size();
    }
    
    public long getOverdueCount() {
        return getOverdueIssues().size();
    }
    
    // Get issues by member
    public List<BookIssue> getIssuesByMember(String memberEmail) {
        return bookIssueRepository.findByMemberEmail(memberEmail);
    }
    
    public BookIssue getIssueById(Long id) {
        return bookIssueRepository.findById(id).orElse(null);
    }
    
    // Total fine for member
    public double getTotalFineByMember(String memberEmail) {
        List<BookIssue> issues = getIssuesByMember(memberEmail);
        double totalFine = 0.0;
        for (BookIssue issue : issues) {
            if (issue.getFineAmount() != null) {
                totalFine += issue.getFineAmount();
            }
        }
        return totalFine;
    }

    public Map<String, Object> getMemberStats(String memberEmail) {
        List<String> borrowStatuses = Arrays.asList("ISSUED", "RETURNED");
        long totalBorrowed = bookIssueRepository.countByMemberEmailAndStatusIn(memberEmail, borrowStatuses);
        long activeReservations = bookIssueRepository.countByMemberEmailAndStatusIn(memberEmail, Arrays.asList("RESERVED"));
        Double pendingFinesObj = bookIssueRepository.sumPendingFinesByMemberEmail(memberEmail);
        double pendingFines = pendingFinesObj != null ? pendingFinesObj : 0.0;
        
        Map<String, Object> stats = new HashMap<>();
        stats.put("totalBorrowed", totalBorrowed);
        stats.put("activeReservations", activeReservations);
        stats.put("pendingFines", pendingFines);
        return stats;
    }
    
    public List<BookIssue> getDueSoonAlerts(String memberEmail) {
        return bookIssueRepository.findDueSoonByMemberEmail(memberEmail);
    }
    
    public List<Book> getRecommendations(String memberEmail) {
        List<BookIssue> recentIssues = bookIssueRepository.findRecentByMemberEmailAndStatus(memberEmail, Arrays.asList("ISSUED", "RETURNED"));
        if (recentIssues.isEmpty()) {
            // Fallback to top 3 available books
            List<Book> available = bookRepository.findByAvailabilityStatus("Available");
            return available.stream().limit(3).collect(Collectors.toList());
        }
        
        Long lastBookId = recentIssues.get(0).getBookId();
        Optional<Book> lastBookOpt = bookRepository.findById(lastBookId);
        if (lastBookOpt.isEmpty()) {
            List<Book> available = bookRepository.findByAvailabilityStatus("Available");
            return available.stream().limit(3).collect(Collectors.toList());
        }
        
        String lastCategory = lastBookOpt.get().getCategory();
        List<Book> recs = bookRepository.findByCategoryAndAvailabilityStatusOrderByIdDesc(lastCategory, "Available");
        if (recs.isEmpty()) {
            List<Book> available = bookRepository.findByAvailabilityStatus("Available");
            return available.stream().limit(3).collect(Collectors.toList());
        }
        return recs.stream().limit(3).collect(Collectors.toList());
    }
}

