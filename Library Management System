package com.example.demo;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.stereotype.Repository;
import java.util.List;


public interface BookIssueRepository extends JpaRepository<BookIssue, Long> {
    List<BookIssue> findAll();
    List<BookIssue> findByStatus(String status);
    List<BookIssue> findByMemberEmail(String memberEmail);
    List<BookIssue> findByBookIdAndStatus(Long bookId, String status);
    
    long countByMemberEmailAndStatusIn(String memberEmail, List<String> statuses);
    
    @Query("SELECT i FROM BookIssue i WHERE i.memberEmail = :email AND i.status IN :statuses ORDER BY i.issueDate DESC")
    List<BookIssue> findRecentByMemberEmailAndStatus(String email, List<String> statuses);
    
    @Query(value = "SELECT SUM(fi.fine_amount) FROM book_issues fi WHERE fi.member_email = :email AND fi.fine_amount > 0 AND (fi.status = 'OVERDUE' OR fi.status = 'ISSUED')", nativeQuery = true)
    Double sumPendingFinesByMemberEmail(String email);
    
    @Query(value = "SELECT * FROM book_issues WHERE member_email = :email AND status = 'ISSUED' AND due_date BETWEEN CURDATE() AND DATE_ADD(CURDATE(), INTERVAL 48 HOUR) ORDER BY due_date ASC", nativeQuery = true)
    List<BookIssue> findDueSoonByMemberEmail(String email);

}
