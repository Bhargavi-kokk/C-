package com.example.demo;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.*;
import jakarta.servlet.http.HttpSession;
import java.time.LocalDate;
import java.util.*;
import java.util.stream.Collectors;
import org.springframework.web.bind.annotation.ResponseBody;


@Controller
public class BookController {
    @Autowired
    private BookService bookService;
    
    @Autowired
    private BookIssueService bookIssueService;
    
    // Home Page
    @GetMapping("/")
    public String home() {
        return "index";
    }
    
    // Login Page
    @GetMapping("/login")
    public String login() {
        return "login";
    }
    
    // Librarian Dashboard - Full CRUD + Issue Management
    @GetMapping("/librarian/dashboard")
    public String librarianDashboard(Model model) {
        model.addAttribute("books", bookService.getAllBooks());
        model.addAttribute("availableCount", bookService.getAvailableBooksCount());
        model.addAttribute("issuedCount", bookIssueService.getIssuedCount());
        model.addAttribute("overdueCount", bookIssueService.getOverdueCount());
        model.addAttribute("role", "Librarian");
        return "librarian-dashboard";
    }
    
    // Member Dashboard - View Only + Reserve
@GetMapping("/member/dashboard")
    public String memberDashboard(Model model, HttpSession session) {
        String memberEmail = (String) session.getAttribute("currentUserEmail");
        if (memberEmail == null) {
            return "redirect:/login?error=noSession";
        }
        
        Map<String, Object> memberStats = bookIssueService.getMemberStats(memberEmail);
        List<BookIssue> dueSoonAlerts = bookIssueService.getDueSoonAlerts(memberEmail);
        List<Book> recommendations = bookIssueService.getRecommendations(memberEmail);
        List<Book> books = bookService.getAllBooks();
        
        model.addAttribute("memberEmail", memberEmail);
        model.addAttribute("memberStats", memberStats);
        model.addAttribute("dueSoonAlerts", dueSoonAlerts);
        model.addAttribute("recommendations", recommendations);
        model.addAttribute("books", books);
        model.addAttribute("role", "Member");
        return "member-dashboard";
    }
    
    @GetMapping("/api/member/books/filter")
    @ResponseBody
    public List<Book> filterBooks(
            @RequestParam(defaultValue = "all") String availability,
            @RequestParam(defaultValue = "all") String category,
            HttpSession session) {
        String memberEmail = (String) session.getAttribute("currentUserEmail");
        if (memberEmail == null) {
            return java.util.Collections.emptyList();
        }
        
        java.util.List<Book> filteredBooks = bookService.getAllBooks();
        
        if (!"all".equals(availability)) {
            filteredBooks = filteredBooks.stream()
                .filter(b -> b.getAvailabilityStatus().equalsIgnoreCase(availability))
                .collect(java.util.stream.Collectors.toList());
        }
        
        if (!"all".equals(category)) {
            filteredBooks = filteredBooks.stream()
                .filter(b -> b.getCategory().equalsIgnoreCase(category))
                .collect(java.util.stream.Collectors.toList());
        }
        
        return filteredBooks;
    }
    
    // ==================== BOOK CRUD ====================

    
    // Add Book Form (Librarian only)
    @GetMapping("/librarian/add")
    public String addBookForm(Model model) {
        model.addAttribute("book", new Book());
        return "add-book";
    }
    
    // Save Book (Librarian only)
    @PostMapping("/librarian/saveBook")
    public String saveBook(@ModelAttribute Book book) {
        book.setAvailabilityStatus("Available");
        bookService.saveBook(book);
        return "redirect:/librarian/dashboard";
    }
    
    // Edit Book Form (Librarian only)
    @GetMapping("/librarian/edit/{id}")
    public String editBookForm(@PathVariable Long id, Model model) {
        Book book = bookService.getBookById(id);
        model.addAttribute("book", book);
        return "edit-book";
    }
    
    // Update Book (Librarian only)
    @PostMapping("/librarian/updateBook")
    public String updateBook(@ModelAttribute Book book) {
        bookService.updateBook(book);
        return "redirect:/librarian/dashboard";
    }
    
    // Delete Book (Librarian only)
    @GetMapping("/librarian/delete/{id}")
    public String deleteBook(@PathVariable Long id) {
        bookService.deleteBook(id);
        return "redirect:/librarian/dashboard";
    }
    
    // ==================== BOOK ISSUE/RETURN ====================
    
    // Issue Book Form
    @GetMapping("/librarian/issue/{id}")
    public String issueBookForm(@PathVariable Long id, Model model) {
        Book book = bookService.getBookById(id);
        model.addAttribute("book", book);
        return "issue-book";
    }
    
    // Issue Book - Process
    @PostMapping("/librarian/issueBook")
    public String issueBook(@RequestParam Long bookId, 
                           @RequestParam String memberName,
                           @RequestParam String memberEmail) {
        BookIssue issue = bookIssueService.issueBook(bookId, memberName, memberEmail);
        if (issue != null) {
            return "redirect:/librarian/dashboard?success=issued";
        }
        return "redirect:/librarian/dashboard?error=alreadyIssued";
    }
    
    // Return Book
    @GetMapping("/librarian/return/{id}")
    public String returnBook(@PathVariable Long id, Model model) {
        BookIssue issue = bookIssueService.returnBook(id);
        model.addAttribute("issue", issue);
        return "return-confirmation";
    }
    
    // View All Issued Books
    @GetMapping("/librarian/issued-books")
    public String viewIssuedBooks(Model model) {
        model.addAttribute("issues", bookIssueService.getActiveIssues());
        return "issued-books";
    }
    
    // View Overdue Books
    @GetMapping("/librarian/overdue-books")
    public String viewOverdueBooks(Model model) {
        model.addAttribute("issues", bookIssueService.getOverdueIssues());
        return "overdue-books";
    }
    
    // Librarian Members Page
    @GetMapping("/librarian/members")
    public String viewMembers(Model model) {
        model.addAttribute("issues", bookIssueService.getAllIssues());
        return "members";
    }
    
    // Member Reservations
@PostMapping("/member/reserveBook")
    public String reserveBook(@RequestParam Long bookId, @RequestParam String memberName, @RequestParam String memberEmail, HttpSession session) {
        String sessionEmail = (String) session.getAttribute("currentUserEmail");
        if (!memberEmail.equals(sessionEmail)) {
            return "redirect:/member/dashboard?error=invalidEmail";
        }
        
        BookIssue reservation = bookIssueService.reserveBook(bookId, memberName, memberEmail);
        if (reservation != null) {
            return "redirect:/member/dashboard?success=reserved-" + bookId;
        }
        return "redirect:/member/dashboard?error=bookUnavailable";

    }

    @GetMapping("/member/my-reservations")
    public String myReservations(Model model, HttpSession session) {
        String userEmail = (String) session.getAttribute("currentUserEmail");
        if (userEmail == null) {
            return "redirect:/member/dashboard?error=noSession";
        }
        model.addAttribute("issues", bookIssueService.getIssuesByMember(userEmail));
        return "my-reservations";
    }
}


